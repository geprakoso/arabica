# ============================================
# APPLICATION CONFIGURATION
# ============================================
APP_NAME=Arabica
APP_ENV=production
# Harus generate dengan: php artisan key:generate
APP_KEY=
APP_DEBUG=false
APP_URL=http://192.168.1.50:8080
# Atau gunakan domain: APP_URL=https://arabica.yourdomain.com
APP_TIMEZONE=Asia/Jakarta
FILESYSTEM_PUBLIC_URL=/storage

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=arabica_db
DB_USERNAME=arabica_user
DB_PASSWORD="C4Tti!PEcc20lZ8M"
DB_ROOT_PASSWORD="hD$jF3ljrTeo^5E9"

# ============================================
# CACHE & SESSION CONFIGURATION
# ============================================
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=redis
REDIS_PASSWORD="LR60Gq!pgXAeM3Mg"
REDIS_PORT=6379
REDIS_CLIENT=phpredis

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ============================================
# SECURITY CONFIGURATION
# ============================================
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
BCRYPT_ROUNDS=12

# ============================================
# MAINTENANCE & CACHE
# ============================================
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# ============================================
# MAIL CONFIGURATION (Set sesuai kebutuhan)
# ============================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@arabica.local"
MAIL_FROM_NAME="${APP_NAME}"

# Jika ingin menggunakan SMTP Mailtrap, uncomment dan set:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=465
# MAIL_USERNAME=your-mailtrap-username
# MAIL_PASSWORD=your-mailtrap-password

# ============================================
# AWS S3 (Optional - untuk file storage)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================
# VITE & FRONTEND
# ============================================
VITE_APP_NAME="${APP_NAME}"

# ============================================
# EXTERNAL API (Optional)
# ============================================
OPENWEATHER_API_KEY=
OPENWEATHER_CITY="Jakarta,ID"
OPENWEATHER_UNITS=metric
OPENWEATHER_CACHE_MINUTES=15

# ============================================
# NGINX PORT (customize sesuai kebutuhan)
# ============================================
NGINX_PORT=8080